# Copia este archivo a .env y rellena los valores.
PORT=3000

# Panel de administración
ADMIN_USER=prueba
ADMIN_PASS=prueba

# Secreto para firmar los tokens de sesión del admin (cámbialo)
SESSION_SECRET=cambia-este-secreto

# Resend (envío de emails). Consigue tu clave en https://resend.com
RESEND_API_KEY=
# Hasta verificar tu dominio en Resend usa onboarding@resend.dev como remitente.
RESEND_FROM=GEST26 Web <onboarding@resend.dev>
# Destinatario de los avisos de nuevos leads.
RESEND_TO=tu-email@ejemplo.com

# Base de datos (Supabase) — opcional pero recomendado para que los leads
# no se borren nunca y aparezcan en /admin también online.
# Déjalo vacío para usar almacenamiento en fichero (se pierde al redesplegar).
SUPABASE_URL=
SUPABASE_KEY=
